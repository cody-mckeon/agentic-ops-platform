{
  "name": "agentic-ops-platform",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  },
  "postCreateCommand": "pip install -U pip && pip install pytest ruff pydantic",
  "remoteUser": "vscode"
}
